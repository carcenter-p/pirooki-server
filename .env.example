# ─── פריורטי ───────────────────────────────────────
# כתובת ה-API של פריורטי (תקבל מהספק)
PRIORITY_BASE_URL=https://p.priority-connect.online/odata/Priority/tabb0864.ini/acr2025

# שם משתמש וסיסמה לגישה ל-API (תקבל מהספק)
PRIORITY_USER=YOUR_PRIORITY_USERNAME
PRIORITY_PASS=YOUR_PRIORITY_PASSWORD

# ─── אבטחה ─────────────────────────────────────────
# מפתח סודי לחתימת טוקנים — שנה לכל מחרוזת אקראית ארוכה
JWT_SECRET=replace-this-with-a-long-random-secret-string-12345

# ─── שרת ───────────────────────────────────────────
PORT=3000
